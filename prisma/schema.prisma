// 生成 Prisma 客户端代码
generator client {
  provider = "prisma-client-js"
}

// 数据库连接信息

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  role      Role     @default(CUSTOMER)
  orders    Order[]
  createdAt DateTime @default(now())
}

model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  order     Int
  visible   Boolean    @default(true)
  menuItems MenuItem[]
}

model MenuItem {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Decimal
  imageUrl     String?
  available    Boolean  @default(true)
  category     Category? @relation(fields: [categoryId], references: [id])
  categoryId   String?
  deleted      Boolean  @default(false)
  optionGroups MenuOptionGroup[]
  orderItems   OrderItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OptionGroupTemplate {
  id       String   @id @default(uuid())
  name     String
  required Boolean
  options  OptionTemplate[]
}

model OptionTemplate {
  id         String   @id @default(uuid())
  name       String
  priceDelta Decimal  @default(0)
  type       OptionType @default(SINGLE_CHOICE)
  group      OptionGroupTemplate @relation(fields: [groupId], references: [id])
  groupId    String
}

model MenuOptionGroup {
  id         String   @id @default(uuid())
  name       String
  required   Boolean  @default(false)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId String
  templateId String?
  deleted    Boolean  @default(false)
  options    MenuOption[]
}

model MenuOption {
  id         String   @id @default(uuid())
  name       String
  priceDelta Decimal  @default(0)
  type       OptionType @default(SINGLE_CHOICE)
  group      MenuOptionGroup @relation(fields: [groupId], references: [id])
  groupId    String
  deleted    Boolean  @default(false)
}

model Order {
  id            String        @id @default(uuid())
  phone         String
  name          String
  status        OrderStatus   @default(PENDING)
  totalPrice    Decimal
  paymentStatus PaymentStatus @default(UNPAID)
  orderSource   String?
  customerNote  String?
  userId        String?
  user          User?         @relation(fields: [userId], references: [id])
  items         OrderItem[]
  createdAt     DateTime      @default(now())
}

model OrderItem {
  id               String   @id @default(uuid())
  order            Order    @relation(fields: [orderId], references: [id])
  orderId          String
  menuItem         MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId       String
  menuItemName     String
  menuItemImage    String?
  menuItemCategory String?
  quantity         Int
  note             String?
  options          OrderItemOption[]
  unitPrice        Decimal
}

model OrderItemOption {
  id           String    @id @default(uuid())
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id])
  orderItemId  String
  groupName    String?
  optionName   String
  priceDelta   Decimal
  quantity     Int
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
}

enum Role {
  CUSTOMER
  ADMIN
  MANAGER
  STAFF
  READONLY
}

enum OptionType {
  SINGLE_CHOICE
  MULTI_SELECT
  QUANTITY
}
